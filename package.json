{
  "name": "@tfmurad/llms-generator",
  "version": "1.0.3",
  "description": "Universal CLI tool to generate llms.txt and llms-full.txt for any static site (Astro, Next.js)",
  "type": "module",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "bin": {
    "llms-txt": "bin/llms-txt.js"
  },
  "files": [
    "bin/",
    "scripts/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "llms-txt",
    "llms",
    "ai",
    "astro",
    "nextjs",
    "static-site",
    "markdown",
    "cli"
  ],
  "author": "Al Murad Uzzaman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tfmurad/llms-generator.git"
  },
  "homepage": "https://github.com/tfmurad/llms-generator#readme",
  "bugs": {
    "url": "https://github.com/tfmurad/llms-generator/issues"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "glob": "^13.0.6",
    "node-html-parser": "^7.1.0",
    "turndown": "^7.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
